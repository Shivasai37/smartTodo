{
  "name": "smarttodo",
  "version": "1.0.0",
  "description": "A production-ready full-stack SmartTodo application built with the MERN stack",
  "main": "server/index.js",
  "scripts": {
    "start:server": "node server/index.js",
    "dev:server": "nodemon server/index.js",
    "dev:client": "cd client && npm run dev",
    "dev:db": "json-server --watch database/db.json --port 3001",
    "dev": "concurrently \"npm run dev:db\" \"npm run dev:server\" \"npm run dev:client\"",
    "install:client": "cd client && npm install",
    "install:all": "npm install && npm run install:client",
    "build:client": "cd client && npm run build",
    "start": "concurrently \"npm run dev:db\" \"npm run start:server\""
  },
  "dependencies": {
    "axios": "^1.7.0",
    "bcryptjs": "^2.4.3",
    "concurrently": "^8.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.18.0",
    "json-server": "^0.17.4",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
